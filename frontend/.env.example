# Development: leave unset — the browser calls /api and Vite proxies to the backend (see vite.config.ts).
#
# Production / static hosting: set the full API origin (scheme + host + port), no path, no trailing slash.
# Do not add `/api` — all client paths already start with `/api/...` (`http://localhost:5000`, not `…/api`).
# Example: https://api.yourschool.com
# VITE_API_BASE_URL=https://api.yourschool.com
#
# Preview build against local API:
# VITE_API_BASE_URL=http://localhost:5000
