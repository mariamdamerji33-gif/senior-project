# Copy this file to `backend/.env` (same folder as `server.js`).
# If writes fail, confirm this file is NOT only at the repo root — the server loads `backend/.env` explicitly.
# No quotes around values. The service_role key is long and starts with `eyJ`.

# production | development — production enforces JWT length, CORS, and stricter errors
# NODE_ENV=production

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use the anon (public) JWT key (starts with eyJ...) from the API settings page.
SUPABASE_ANON_KEY=
# Required for server-side writes and bypassing RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Postgres URI for DDL scripts only (same place as Dashboard SQL). Not used by the API at runtime.
# Example: postgres://postgres.[project-ref]:[YOUR-DB-PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres
# DATABASE_URL=

PORT=5000
# Restart the Node server after edits to `.env`; rate-limit state also resets when the process restarts.
# Rate limiting: in development it is skipped by default so local sign-in/forgot/register are not capped.
# Set FORCE_RATE_LIMIT=true to enforce limits locally. Set DISABLE_API_RATE_LIMIT=true (any NODE_ENV) to turn off API rate limiting entirely — use only while debugging or on trusted networks.
# FORCE_RATE_LIMIT=true
# DISABLE_API_RATE_LIMIT=true
# Use a long random string. In production (NODE_ENV=production) it must be at least 32 characters.
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars_prod
# Optional token lifetime for JWT (default 7d). Examples: 24h, 7d, 30d
# JWT_EXPIRES_IN=7d
# Optional migration step: also issue HttpOnly auth cookie on login (keeps Bearer token response for compatibility).
# AUTH_COOKIE_ENABLED=true
# AUTH_COOKIE_NAME=asp_auth
# Optional CSRF names (defaults shown):
# CSRF_COOKIE_NAME=asp_csrf
# CSRF_HEADER_NAME=x-csrf-token
# Audit log (JSON lines). Enabled by default.
# AUDIT_LOG_ENABLED=true
# AUDIT_LOG_PATH=backend/logs/audit.log

# CORS (no trailing slash). Production requires at least one origin below.
# Dev automatically allows both http://localhost:5173 and http://127.0.0.1:5173 — use the same hostname in the browser URL as in this list if you override CORS.
# Dev default if unset: http://localhost:5173. GET /login on the API redirects to FRONTEND_ORIGIN/login when set.
# FRONTEND_ORIGIN=https://your-school-app.example.com
# FRONTEND_ORIGIN=http://localhost:5173
# Also used to build dev-only password-reset links in POST /api/auth/forgot-password responses (non-production).
# Optional extra origins (comma-separated), e.g. staging:
# CORS_ORIGINS=https://staging.example.com

# Optional SMTP — by default only “account created” + “password updated” (with login link).
# Set SMTP_SEND_PASSWORD_RESET_EMAIL=true to also email reset links on forgot-password.
#
# --- Gmail (Google) ---
# 1) Use a Google account that will send mail (often a dedicated school@gmail.com).
# 2) Turn on 2-Step Verification: https://myaccount.google.com/security
# 3) Create an App password: Google Account → Security → 2-Step Verification → App passwords
#    (choose “Mail” / “Other” → copy the 16-character password; paste as SMTP_PASS with no spaces).
# 4) Set SMTP_HOST, SMTP_PORT, SMTP_SECURE, SMTP_USER, SMTP_PASS below (and SMTP_FROM if you want a custom From name).
# SMTP_FROM optional if SMTP_USER is already a full email — server uses
#   Autism School Platform <SMTP_USER>
# when SMTP_FROM is empty.
# 5) Restart the backend after saving backend/.env
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM="Autism School Platform <you@gmail.com>"
# SMTP_SEND_PASSWORD_RESET_EMAIL=false
#
# Alternative Gmail (SSL): SMTP_PORT=465 and SMTP_SECURE=true
#
# For a custom domain on Google Workspace, same host/ports; SMTP_USER is the full Workspace email
# and the admin may need to allow “less secure” / App passwords per Workspace policy.

# Local demo seed accounts. Keep these defaults for a classroom demo only.
# Rotate/change passwords before connecting to real student data.
# Run order from repo root after backend/.env is filled:
#   npm run seed:school-users --prefix backend
# Optional single-admin seed:
#   npm run seed:super-admin --prefix backend
# SEED_SCHOOL_ADMIN_EMAIL=schooladmin@asp.com
# SEED_SCHOOL_ADMIN_PASSWORD=AspAdmin123
# SEED_COORDINATOR_EMAIL=coordinator@asp.com
# SEED_COORDINATOR_PASSWORD=AspCoord123
# SEED_TEACHER_EMAIL=teacher@asp.com
# SEED_TEACHER_PASSWORD=AspTeach123
# SEED_FAMILY_EMAIL=family@asp.com
# SEED_FAMILY_PASSWORD=AspFamily123
# SEED_SUPER_ADMIN_EMAIL=admin@example.com
# SEED_SUPER_ADMIN_PASSWORD=Admin123456
# SEED_SUPER_ADMIN_NAME=Super Admin
